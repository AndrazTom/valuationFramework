#!/usr/bin/env bash
set -euo pipefail

if [ -f ".env" ]; then
  set -a
  # shellcheck disable=SC1091
  . ./.env
  set +a
fi

if [ ! -x ".venv/bin/python" ]; then
  echo "Error: local environment not found. Run ./setup first." >&2
  exit 1
fi

export PYTHONPATH="src${PYTHONPATH:+:$PYTHONPATH}"
exec ./.venv/bin/python -m valuation.cli "$@"
